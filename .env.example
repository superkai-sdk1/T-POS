# Telegram бот-токен (серверный, НЕ используйте VITE_ префикс!)
TELEGRAM_BOT_TOKEN=your-bot-token
CLIENT_BOT_TOKEN=your-client-bot-token
WALLET_DOMAIN=wallet.titanpos.ru
POS_DOMAIN=titanpos.ru
VITE_WALLET_BOT_USERNAME=titanwalletrobot
API_SECRET=your-api-secret-key
OWNER_CHAT_IDS=556525624,1005574994
# AI-ассистент (чат, отчёты) — ключ с polza.ai/dashboard/api-keys
POLZA_AI_API_KEY=

# ==================
# Локальный Postgres (для миграции с Supabase)
# ==================
POSTGRES_PASSWORD=change_this_password_in_production
DATABASE_URL=postgresql://tpos:change_this_password_in_production@localhost:5432/tpos

# ==================
# MinIO (S3-совместимое хранилище)
# ==================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_password_in_production
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_password_in_production
MINIO_USE_SSL=false
